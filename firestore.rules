rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    match /zones/{zoneId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin()
        && request.resource.data.zoneId == zoneId
        && request.resource.data.density in ['low', 'medium', 'high', 'critical']
        && request.resource.data.queueMinutes is number
        && request.resource.data.queueMinutes >= 0
        && request.resource.data.queueMinutes <= 240
        && request.resource.data.footfall is number
        && request.resource.data.footfall >= 0
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 100
        && request.resource.data.alertLevel in ['green', 'amber', 'red'];
      allow delete: if false;
    }

    match /simulationEvents/{eventId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.zoneId is string
        && request.resource.data.zoneId.size() > 0
        && request.resource.data.density in ['low', 'medium', 'high', 'critical']
        && request.resource.data.queueMinutes is number
        && request.resource.data.queueMinutes >= 0
        && request.resource.data.queueMinutes <= 240
        && request.resource.data.footfall is number
        && request.resource.data.footfall >= 0;
      allow update, delete: if false;
    }

    match /alerts/{alertId} {
      allow read: if isSignedIn();
      allow create: if isAdmin()
        && request.resource.data.zoneId is string
        && request.resource.data.zoneId.size() > 0
        && request.resource.data.level in ['amber', 'red']
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 100
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0;
      allow update, delete: if false;
    }

    match /recommendations/{zoneId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin()
        && request.resource.data.zoneId == zoneId
        && request.resource.data.action in ['monitor', 'preemptive-dispatch', 'reroute']
        && request.resource.data.headline is string
        && request.resource.data.guidance is string
        && request.resource.data.attendeeMessage is string
        && request.resource.data.operatorAction is string
        && request.resource.data.rerouteZone is string
        && request.resource.data.expectedQueueDeltaMinutes is number
        && request.resource.data.expectedQueueDeltaMinutes >= 0
        && request.resource.data.expectedQueueDeltaMinutes <= 60
        && request.resource.data.severity in ['green', 'amber', 'red']
        && request.resource.data.source in ['deterministic-fallback', 'vertex-ai']
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 100;
      allow delete: if false;
    }

    match /translations/{translationId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin()
        && request.resource.data.locale is string
        && request.resource.data.sourceText is string
        && request.resource.data.text is string;
      allow delete: if false;
    }

    match /profiles/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role == null;
      allow update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role;
      allow delete: if false;
    }
  }
}
